rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email == 'saransh1860@gmail.com' && request.auth.token.email_verified)
      );
    }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    match /consultations/{id} {
      allow create: if isValidId(id) && 
                      request.resource.data.keys().hasAll(['name', 'phone', 'service', 'status', 'createdAt']) &&
                      request.resource.data.keys().size() == 5 &&
                      request.resource.data.name is string && request.resource.data.name.size() <= 100 &&
                      request.resource.data.phone is string && request.resource.data.phone.size() <= 20 &&
                      request.resource.data['service'] is string && request.resource.data['service'].size() <= 100 &&
                      request.resource.data.status == 'pending' &&
                      request.resource.data.createdAt == request.time;
                      
      allow update: if isValidId(id) &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
                      request.resource.data.status in ['pending', 'contacted', 'completed', 'cancelled'];
                      
      allow get, list: if true;
    }

    match /messages/{id} {
        allow create: if isValidId(id) &&
                        request.resource.data.keys().hasAll(['name', 'phone', 'email', 'message', 'createdAt']) &&
                        request.resource.data.keys().size() == 5 &&
                        request.resource.data.name is string && request.resource.data.name.size() <= 100 &&
                        request.resource.data.phone is string && request.resource.data.phone.size() <= 20 &&
                        request.resource.data.email is string && request.resource.data.email.size() <= 100 &&
                        request.resource.data.message is string && request.resource.data.message.size() <= 5000 &&
                        request.resource.data.createdAt == request.time;
        allow get, list: if true;
    }

    match /admins/{uid} {
      allow get: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();
    }
  }
}
